{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "_comment": "Example Vercel Pro cron overrides — merge into vercel.json when higher frequency is allowed.",
  "crons": [
    {
      "path": "/api/cron/smart-fill",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/recall",
      "schedule": "0 7 * * *"
    }
  ]
}
