{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && HUSKY=0 yarn install --immutable",
  "buildCommand": "cd ../.. && HUSKY=0 SKIP_DB_MIGRATIONS=1 yarn build",
  "crons": [
    {
      "path": "/api/cron/calendar-subscriptions-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/tasks/cleanup",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/smart-fill",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/recall",
      "schedule": "0 7 * * *"
    }
  ],
  "functions": {
    "app/api/trpc/**": {
      "maxDuration": 60
    },
    "pages/api/trpc/**": {
      "maxDuration": 60
    }
  }
}
