# Supabase PostgreSQL — copy to repo root as .env (never commit .env)
# Dashboard: https://supabase.com/dashboard → Project → Settings → Database

# Direct connection (port 5432) — required for migrations.
# Use Supabase SESSION pooler (reachable from Vercel/CI), NOT db.*.supabase.co direct host.
DATABASE_DIRECT_URL="postgresql://postgres.sozarwmazweyiiookfxg:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Transaction pooler (port 6543) — Vercel runtime only
DATABASE_URL="postgresql://postgres.sozarwmazweyiiookfxg:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

NEXT_PUBLIC_WEBAPP_URL="https://your-project.vercel.app"
