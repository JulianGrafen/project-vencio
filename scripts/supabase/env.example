# Supabase PostgreSQL — copy to repo root as .env (never commit .env)
# Dashboard: https://supabase.com/dashboard → Project → Settings → Database

# Direct connection (port 5432) — required for migrations (user: postgres, not postgres.<ref>)
DATABASE_DIRECT_URL="postgresql://postgres:[PASSWORD]@db.sozarwmazweyiiookfxg.supabase.co:5432/postgres?sslmode=require"

# Transaction pooler (port 6543) — Vercel runtime
# DATABASE_URL="postgresql://postgres.sozarwmazweyiiookfxg:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# After running supabase-sql-editor-setup.sql in Supabase SQL Editor, set in Vercel:
# SKIP_DB_MIGRATIONS=1

NEXT_PUBLIC_WEBAPP_URL="https://your-project.vercel.app"
NEXTAUTH_URL="https://your-project.vercel.app/api/auth"
NEXTAUTH_SECRET=
CALENDSO_ENCRYPTION_KEY=
