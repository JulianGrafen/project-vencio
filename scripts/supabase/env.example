# Supabase PostgreSQL — copy to repo root as .env (never commit .env)
# Dashboard: https://supabase.com/dashboard → Project → Settings → Database

# Transaction pooler (port 6543) — app runtime on Vercel
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct / session pooler (port 5432) — Prisma migrations only
DATABASE_DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Alternative direct host (also works for migrations):
# DATABASE_DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

NEXT_PUBLIC_WEBAPP_URL="https://your-project.vercel.app"
NEXTAUTH_URL="https://your-project.vercel.app/api/auth"
NEXTAUTH_SECRET=
CALENDSO_ENCRYPTION_KEY=
